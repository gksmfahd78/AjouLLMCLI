{
  "name": "ajoullm-cli",
  "version": "0.1.1",
  "description": "A small CLI for chatting with Mindlogic Gateway models.",
  "bin": {
    "ajoullm": "bin/ajoullm.js"
  },
  "files": [
    "ajoullm.cmd",
    "ajoullm.ps1",
    "bin",
    "lib",
    "README.md"
  ],
  "type": "commonjs",
  "scripts": {
    "start": "node ./bin/ajoullm.js",
    "chat": "node ./bin/ajoullm.js chat",
    "config": "node ./bin/ajoullm.js config",
    "check": "node ./scripts/check.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "license": "MIT"
}
